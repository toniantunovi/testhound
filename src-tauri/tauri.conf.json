{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TestHound",
  "version": "0.7.9",
  "identifier": "app.testhound.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TestHound",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0B0D10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Voldeq GmbH",
    "copyright": "Copyright © 2026 Voldeq GmbH",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/toniantunovi/testhound/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwMjAwNEQzRDYzMTIxMTIKUldRU0lUSFcwd1Fna0JCbWYzMWRDMENhNHhwSVpEeFVlRUxJRVFXMExra3lsT3FWYUpueEQ1Tk4K"
    }
  }
}
